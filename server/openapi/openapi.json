{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "Yap Server API",
    "version": "1.0.0",
    "description": "Normative Yap server wire contract. Phase 3 implements only GET /v1/health. Job, chunk, commit, and live-session operations are contract-only boundaries owned by Phase 5."
  },
  "tags": [
    {
      "name": "health",
      "description": "Implemented Phase 3 process health."
    },
    {
      "name": "jobs",
      "description": "Contract-only Phase 5 batch job and resumable upload boundary."
    },
    {
      "name": "live",
      "description": "Contract-only Phase 5 WebSocket upgrade boundary."
    }
  ],
  "paths": {
    "/v1/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Read server health and implemented capabilities",
        "description": "The only server behavior implemented in Phase 3. A capability remains false until its real handler exists.",
        "operationId": "getHealth",
        "x-yap-phase-3-behavior": "Implemented",
        "x-yap-later-owner": "Server process",
        "responses": {
          "200": {
            "description": "The process is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthView"
                },
                "examples": {
                  "ok": {
                    "externalValue": "./examples/health.ok.json"
                  }
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/ApiErrorResponse"
          }
        }
      }
    },
    "/v1/jobs": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Create a recording job",
        "description": "Phase 5 contract only. Phase 3 has no upload intake, queue, persistence, auth, or inference implementation. The request never supplies tenant or owner-subject identity; a future authenticated server derives those values from a validated token.",
        "operationId": "createJob",
        "x-yap-phase-3-behavior": "Contract only",
        "x-yap-later-owner": "Phase 5 upload intake",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecordingJobRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "The job contract was accepted for future upload processing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordingJob"
                },
                "examples": {
                  "accepted": {
                    "externalValue": "./examples/job.accepted.json"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "429": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      }
    },
    "/v1/jobs/{jobId}": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Read recording job status",
        "description": "Phase 5 contract only. Phase 3 does not persist or report jobs.",
        "operationId": "getJob",
        "x-yap-phase-3-behavior": "Contract only",
        "x-yap-later-owner": "Phase 5 job status",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobId"
          }
        ],
        "responses": {
          "200": {
            "description": "The current immutable job projection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordingJob"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      },
      "delete": {
        "tags": [
          "jobs"
        ],
        "summary": "Request recording job cancellation",
        "description": "Phase 5 contract only. Cancellation is a state transition request, not proof that already-running work stopped synchronously.",
        "operationId": "cancelJob",
        "x-yap-phase-3-behavior": "Contract only",
        "x-yap-later-owner": "Phase 5 cancellation",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobId"
          }
        ],
        "responses": {
          "202": {
            "description": "Cancellation was recorded or the terminal cancellation state was replayed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordingJob"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "409": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      }
    },
    "/v1/jobs/{jobId}/chunks/{trackId}/{sequenceStart}-{sequenceEnd}": {
      "put": {
        "tags": [
          "jobs"
        ],
        "summary": "Upload one immutable audio chunk",
        "description": "Phase 5 contract only. The body is raw little-endian PCM bytes. Replay identity and byte content identity are independent. Every explicit Yap header and path range must match the chunk entry in the referenced capture manifest; a mismatch is rejected before bytes are accepted.",
        "operationId": "uploadJobChunk",
        "x-yap-phase-3-behavior": "Contract only",
        "x-yap-later-owner": "Phase 5 resumable upload",
        "x-yap-replay-semantics": {
          "sameKeySameHash": "replay_success",
          "sameKeyDifferentHash": {
            "status": 409,
            "code": "CONTENT_IDENTITY_CONFLICT"
          },
          "differentKeySameHash": "allowed",
          "headerManifestMismatch": "reject_before_accept"
        },
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "Opaque server job identifier.",
            "schema": {
              "$ref": "#/components/schemas/JobId"
            }
          },
          {
            "name": "trackId",
            "in": "path",
            "required": true,
            "description": "Track identifier from the immutable capture manifest.",
            "schema": {
              "$ref": "#/components/schemas/TrackId"
            }
          },
          {
            "name": "sequenceStart",
            "in": "path",
            "required": true,
            "description": "Inclusive first frame sequence.",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "sequenceEnd",
            "in": "path",
            "required": true,
            "description": "Inclusive final frame sequence; never less than sequenceStart.",
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": true,
            "description": "Logical replay key formatted as <schema>/<session>/<track>/<sequence-start>/<sequence-end>.",
            "schema": {
              "type": "string",
              "pattern": "^[0-9]+/[A-Za-z0-9_-]+/[A-Za-z0-9_-]+/[0-9]+/[0-9]+$",
              "example": "1/s-01J/track-1/0/159"
            }
          },
          {
            "name": "X-Yap-Content-SHA256",
            "in": "header",
            "required": true,
            "description": "Byte identity for the raw request body, independent of the idempotency key.",
            "schema": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          {
            "name": "X-Yap-Audio-Codec",
            "in": "header",
            "required": true,
            "description": "The raw audio encoding. pcm_s16le is little-endian and therefore is not audio/L16.",
            "schema": {
              "type": "string",
              "const": "pcm_s16le"
            }
          },
          {
            "name": "X-Yap-Sample-Rate-Hz",
            "in": "header",
            "required": true,
            "schema": {
              "type": "integer",
              "const": 16000
            }
          },
          {
            "name": "X-Yap-Channels",
            "in": "header",
            "required": true,
            "schema": {
              "type": "integer",
              "const": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Raw pcm_s16le bytes for exactly the declared sequence range.",
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Same replay key and content hash were already accepted; replay succeeded idempotently.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkUploadReceipt"
                }
              }
            }
          },
          "201": {
            "description": "The new logical chunk and byte identity were accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChunkUploadReceipt"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "409": {
            "description": "The logical replay key was already bound to different bytes.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                },
                "example": {
                  "code": "CONTENT_IDENTITY_CONFLICT",
                  "message": "The chunk replay key is already bound to different content.",
                  "retryable": false,
                  "requestId": "req-01J..."
                }
              }
            }
          },
          "415": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      }
    },
    "/v1/jobs/{jobId}/commit": {
      "post": {
        "tags": [
          "jobs"
        ],
        "summary": "Commit a complete recording upload",
        "description": "Phase 5 contract only. Commit makes the immutable capture manifest eligible for queued server processing after every referenced chunk is present and hash-verified.",
        "operationId": "commitJob",
        "x-yap-phase-3-behavior": "Contract only",
        "x-yap-later-owner": "Phase 5 upload commit",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommitRecordingJobRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "The complete upload was accepted for future processing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordingJob"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "409": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      }
    },
    "/v1/live": {
      "get": {
        "tags": [
          "live"
        ],
        "summary": "Upgrade to the Yap live event protocol",
        "description": "Phase 5 event-schema contract only. Phase 3 has no WebSocket runtime, streaming inference, authentication, or reconnect drain.",
        "operationId": "connectLive",
        "x-yap-phase-3-behavior": "Event schema only",
        "x-yap-later-owner": "Phase 5 WSS streaming",
        "x-yap-live-events-schema": "./live-events.schema.json",
        "responses": {
          "101": {
            "description": "Future WebSocket protocol upgrade.",
            "headers": {
              "Upgrade": {
                "schema": {
                  "type": "string",
                  "const": "websocket"
                }
              },
              "Connection": {
                "schema": {
                  "type": "string",
                  "const": "Upgrade"
                }
              },
              "Sec-WebSocket-Protocol": {
                "schema": {
                  "type": "string",
                  "const": "yap.live.v1"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiErrorResponse"
          },
          "501": {
            "$ref": "#/components/responses/NotImplementedResponse"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "JobId": {
        "name": "jobId",
        "in": "path",
        "required": true,
        "description": "Opaque server job identifier.",
        "schema": {
          "$ref": "#/components/schemas/JobId"
        }
      }
    },
    "responses": {
      "ApiErrorResponse": {
        "description": "The request failed with the stable Yap error envelope.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            }
          }
        }
      },
      "NotImplementedResponse": {
        "description": "The operation is a frozen contract but is not implemented in Phase 3.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiError"
            },
            "example": {
              "code": "NOT_IMPLEMENTED",
              "message": "This route is contract-only in Phase 3.",
              "retryable": false,
              "requestId": "req-01J..."
            }
          }
        }
      }
    },
    "schemas": {
      "OpaqueIdentifier": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9_-]+$"
      },
      "JobId": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9_-]+$",
        "example": "job-01JABCDEF"
      },
      "TrackId": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[A-Za-z0-9_-]+$",
        "example": "track-1"
      },
      "Sha256": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      },
      "UtcDateTime": {
        "type": "string",
        "format": "date-time",
        "pattern": "Z$",
        "description": "RFC 3339 timestamp normalized to UTC with a trailing Z."
      },
      "RecordingJobStatus": {
        "type": "string",
        "description": "Model-agnostic recording workflow status shared with the client state machine.",
        "enum": [
          "accepted",
          "preflighting",
          "blocked_setup_required",
          "blocked_server_unavailable",
          "blocked_sign_in_required",
          "queued_local_fallback",
          "queued_server",
          "preprocessing",
          "uploading",
          "server_processing",
          "local_transcribing",
          "saving",
          "diarization_queued",
          "diarization_running",
          "complete",
          "partial",
          "failed",
          "cancelled"
        ]
      },
      "SessionMode": {
        "type": "string",
        "enum": [
          "dictation",
          "meeting"
        ]
      },
      "SessionOrigin": {
        "type": "string",
        "description": "Immutable capture-manifest value. React projects these values separately for RecordingJobView.",
        "enum": [
          "live_capture",
          "imported_file"
        ],
        "x-yap-recording-job-view-projection": {
          "live_capture": "liveCapture",
          "imported_file": "importedFile"
        }
      },
      "TriggerMode": {
        "type": "string",
        "enum": [
          "push_to_talk",
          "toggle"
        ]
      },
      "AudioRoute": {
        "type": "string",
        "description": "Immutable capture/server route value. React projects these values separately for RecordingJobView.",
        "enum": [
          "local_fallback",
          "server_batch",
          "server_live"
        ],
        "x-yap-recording-job-view-projection": {
          "local_fallback": "localFallback",
          "server_batch": "serverBatch",
          "server_live": "serverLive"
        }
      },
      "CaptureSource": {
        "type": "string",
        "enum": [
          "microphone",
          "system_loopback"
        ]
      },
      "ImportedTrackProvenance": {
        "description": "Imported audio does not claim a physical capture source unless the user declared one.",
        "oneOf": [
          {
            "type": "string",
            "enum": [
              "unknown",
              "mixed"
            ]
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "source"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "user_declared"
              },
              "source": {
                "$ref": "#/components/schemas/CaptureSource"
              }
            }
          }
        ]
      },
      "TrackSource": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "source"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "captured"
              },
              "source": {
                "$ref": "#/components/schemas/CaptureSource"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "provenance"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "imported"
              },
              "provenance": {
                "$ref": "#/components/schemas/ImportedTrackProvenance"
              }
            }
          }
        ],
        "discriminator": {
          "propertyName": "kind"
        }
      },
      "SessionMetadata": {
        "type": "object",
        "additionalProperties": false,
        "description": "Client capture metadata. Field names are camelCase while immutable enum values stay snake_case.",
        "required": [
          "sessionId",
          "mode",
          "origin",
          "triggerMode",
          "startedAtUtc",
          "utcOffsetMinutesAtStart",
          "localeHintBcp47",
          "countryCodeHint",
          "preferredLanguagesBcp47",
          "appVersion",
          "platform",
          "privacyPolicyVersion",
          "retentionExpiresAtUtc"
        ],
        "properties": {
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "mode": {
            "$ref": "#/components/schemas/SessionMode"
          },
          "origin": {
            "$ref": "#/components/schemas/SessionOrigin"
          },
          "triggerMode": {
            "$ref": "#/components/schemas/TriggerMode"
          },
          "startedAtUtc": {
            "type": "string",
            "format": "date-time",
            "pattern": "Z$",
            "description": "Session start normalized to UTC."
          },
          "utcOffsetMinutesAtStart": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": -840,
            "maximum": 840,
            "description": "Optional observed local UTC offset; never inferred from country."
          },
          "localeHintBcp47": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 35,
            "pattern": "^[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*$"
          },
          "countryCodeHint": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[A-Z]{2}$",
            "description": "Optional explicit ISO 3166-1 alpha-2 country hint; never derived from locale or network location."
          },
          "preferredLanguagesBcp47": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 35,
              "pattern": "^[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*$"
            }
          },
          "appVersion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "platform": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "privacyPolicyVersion": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "description": "Capture-time privacy-policy version. The value unconfigured is valid for local capture artifacts but cannot authorize a team upload after authentication and policy gating ship."
          },
          "retentionExpiresAtUtc": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/UtcDateTime"
              },
              {
                "type": "null"
              }
            ],
            "description": "Required as a non-null future UTC time for meeting capture by client policy."
          }
        }
      },
      "CaptureTrackDescriptor": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "trackId",
          "source",
          "deviceId",
          "originalSampleRateHz",
          "originalChannels"
        ],
        "properties": {
          "trackId": {
            "$ref": "#/components/schemas/TrackId"
          },
          "source": {
            "$ref": "#/components/schemas/TrackSource"
          },
          "deviceId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128,
            "description": "Optional opaque installation-scoped device reference; never a raw OS selector or display name."
          },
          "originalSampleRateHz": {
            "type": "integer",
            "minimum": 1
          },
          "originalChannels": {
            "type": "integer",
            "minimum": 1,
            "maximum": 64
          }
        }
      },
      "ChunkReplayKey": {
        "type": "object",
        "additionalProperties": false,
        "description": "Logical server replay identity. Tenant and owner-subject namespace are server-derived only after token validation exists and are never client-provided.",
        "required": [
          "schemaVersion",
          "sessionId",
          "trackId",
          "sequenceStart",
          "sequenceEnd"
        ],
        "properties": {
          "schemaVersion": {
            "type": "integer",
            "minimum": 1
          },
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "trackId": {
            "$ref": "#/components/schemas/TrackId"
          },
          "sequenceStart": {
            "type": "integer",
            "minimum": 0
          },
          "sequenceEnd": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "ContentIdentity": {
        "type": "object",
        "additionalProperties": false,
        "description": "Identity of encoded chunk bytes, independent of the logical replay key.",
        "required": [
          "sha256",
          "byteLength"
        ],
        "properties": {
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "byteLength": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "GapCause": {
        "type": "string",
        "enum": [
          "callback_pool_exhausted",
          "oversized_callback",
          "device_discontinuity",
          "sink_unavailable"
        ]
      },
      "AudioGap": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sessionId",
          "trackId",
          "startMs",
          "durationMs",
          "sourcePositionFrames",
          "droppedFrames",
          "cause",
          "generation"
        ],
        "properties": {
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "trackId": {
            "$ref": "#/components/schemas/TrackId"
          },
          "startMs": {
            "type": "integer",
            "minimum": 0
          },
          "durationMs": {
            "type": "integer",
            "minimum": 1
          },
          "sourcePositionFrames": {
            "type": "integer",
            "minimum": 0
          },
          "droppedFrames": {
            "type": "integer",
            "minimum": 1
          },
          "cause": {
            "$ref": "#/components/schemas/GapCause"
          },
          "generation": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "CaptureManifestReference": {
        "type": "object",
        "additionalProperties": false,
        "description": "Immutable capture-manifest identity. This hash is distinct from every chunk content hash and every later result-revision hash.",
        "required": [
          "schemaVersion",
          "sessionId",
          "sha256",
          "byteLength"
        ],
        "properties": {
          "schemaVersion": {
            "type": "integer",
            "minimum": 1
          },
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "sha256": {
            "$ref": "#/components/schemas/Sha256"
          },
          "byteLength": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "CaptureChunkReference": {
        "type": "object",
        "additionalProperties": false,
        "description": "Expected chunk metadata from the immutable capture manifest. Upload path and headers must match it before body acceptance.",
        "required": [
          "replayKey",
          "contentIdentity",
          "audioCodec",
          "sampleRateHz",
          "channels",
          "startMs",
          "durationMs"
        ],
        "properties": {
          "replayKey": {
            "$ref": "#/components/schemas/ChunkReplayKey"
          },
          "contentIdentity": {
            "$ref": "#/components/schemas/ContentIdentity"
          },
          "audioCodec": {
            "type": "string",
            "const": "pcm_s16le"
          },
          "sampleRateHz": {
            "type": "integer",
            "const": 16000
          },
          "channels": {
            "type": "integer",
            "const": 1
          },
          "startMs": {
            "type": "integer",
            "minimum": 0
          },
          "durationMs": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "ResultAuthority": {
        "type": "string",
        "enum": [
          "local_provisional",
          "local_reconciled",
          "server_authoritative",
          "user_corrected"
        ]
      },
      "ResultStatus": {
        "type": "string",
        "enum": [
          "complete",
          "partial"
        ]
      },
      "SpeakerAttribution": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "unknown"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "sessionSpeakerId"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "session_speaker"
              },
              "sessionSpeakerId": {
                "$ref": "#/components/schemas/OpaqueIdentifier"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "identityRef",
              "displayName",
              "profileRevision"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "named"
              },
              "identityRef": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256,
                "description": "Opaque server-authoritative identity reference, not a client ownership claim."
              },
              "displayName": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              },
              "profileRevision": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            }
          }
        ],
        "discriminator": {
          "propertyName": "kind"
        }
      },
      "SpeakerTurn": {
        "type": "object",
        "additionalProperties": false,
        "description": "End-exclusive [startMs, endMs) speaker interval on the common monotonic session timeline. Overlapping turns remain separate.",
        "required": [
          "turnId",
          "startMs",
          "endMs",
          "attribution",
          "confidence",
          "supportingTrackIds",
          "overlapGroupId"
        ],
        "properties": {
          "turnId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "startMs": {
            "type": "integer",
            "minimum": 0
          },
          "endMs": {
            "type": "integer",
            "minimum": 1
          },
          "attribution": {
            "$ref": "#/components/schemas/SpeakerAttribution"
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "supportingTrackIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "#/components/schemas/TrackId"
            }
          },
          "overlapGroupId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9_-]+$"
          }
        }
      },
      "AlignedWord": {
        "type": "object",
        "additionalProperties": false,
        "description": "End-exclusive aligned raw-word interval. Polished text does not invent independent timestamps.",
        "required": [
          "wordIndex",
          "text",
          "startMs",
          "endMs",
          "turnId",
          "attribution",
          "confidence"
        ],
        "properties": {
          "wordIndex": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "startMs": {
            "type": "integer",
            "minimum": 0
          },
          "endMs": {
            "type": "integer",
            "minimum": 1
          },
          "turnId": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "attribution": {
            "$ref": "#/components/schemas/SpeakerAttribution"
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "ModelRevision": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "modelId",
          "revision",
          "calibrationRevision"
        ],
        "properties": {
          "modelId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "revision": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "calibrationRevision": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      },
      "LanguageDecision": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "languageBcp47",
          "confidence"
        ],
        "properties": {
          "languageBcp47": {
            "type": "string",
            "minLength": 1,
            "maxLength": 35,
            "pattern": "^[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*$"
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "TranscriptResultRevision": {
        "type": "object",
        "additionalProperties": false,
        "description": "Immutable transcript result revision rooted in one immutable capture-manifest hash.",
        "required": [
          "sessionId",
          "revision",
          "authority",
          "createdAtUtc",
          "captureManifestSha256",
          "previousResultSha256",
          "status",
          "language",
          "transcript",
          "alignedWords",
          "modelProvenance"
        ],
        "properties": {
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "revision": {
            "type": "integer",
            "minimum": 1
          },
          "authority": {
            "$ref": "#/components/schemas/ResultAuthority"
          },
          "createdAtUtc": {
            "$ref": "#/components/schemas/UtcDateTime"
          },
          "captureManifestSha256": {
            "$ref": "#/components/schemas/Sha256"
          },
          "previousResultSha256": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Sha256"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ResultStatus"
          },
          "language": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/LanguageDecision"
              },
              {
                "type": "null"
              }
            ]
          },
          "transcript": {
            "type": "string"
          },
          "alignedWords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlignedWord"
            }
          },
          "modelProvenance": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelRevision"
            }
          }
        }
      },
      "SpeakerResultRevision": {
        "type": "object",
        "additionalProperties": false,
        "description": "Immutable speaker result revision. Named attribution is valid only with server_authoritative authority or a later user correction rooted in that evidence.",
        "required": [
          "sessionId",
          "revision",
          "authority",
          "createdAtUtc",
          "captureManifestSha256",
          "previousResultSha256",
          "status",
          "language",
          "speakerTurns",
          "alignedWords",
          "modelProvenance"
        ],
        "properties": {
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "revision": {
            "type": "integer",
            "minimum": 1
          },
          "authority": {
            "$ref": "#/components/schemas/ResultAuthority"
          },
          "createdAtUtc": {
            "$ref": "#/components/schemas/UtcDateTime"
          },
          "captureManifestSha256": {
            "$ref": "#/components/schemas/Sha256"
          },
          "previousResultSha256": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/Sha256"
              },
              {
                "type": "null"
              }
            ]
          },
          "status": {
            "$ref": "#/components/schemas/ResultStatus"
          },
          "language": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/LanguageDecision"
              },
              {
                "type": "null"
              }
            ]
          },
          "speakerTurns": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpeakerTurn"
            }
          },
          "alignedWords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlignedWord"
            }
          },
          "modelProvenance": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelRevision"
            }
          }
        }
      },
      "ServerCapabilities": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "batchJobs",
          "liveStreaming",
          "jobStatus"
        ],
        "properties": {
          "batchJobs": {
            "type": "boolean",
            "description": "True only when batch job intake is implemented."
          },
          "liveStreaming": {
            "type": "boolean",
            "description": "True only when the live WebSocket runtime is implemented."
          },
          "jobStatus": {
            "type": "boolean",
            "description": "True only when durable job status is implemented."
          }
        }
      },
      "HealthView": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "service",
          "status",
          "apiVersion",
          "auth",
          "capabilities"
        ],
        "properties": {
          "service": {
            "type": "string",
            "const": "yap-server"
          },
          "status": {
            "type": "string",
            "const": "ok"
          },
          "apiVersion": {
            "type": "string",
            "const": "1"
          },
          "auth": {
            "type": "string",
            "enum": [
              "not_configured",
              "required"
            ]
          },
          "capabilities": {
            "$ref": "#/components/schemas/ServerCapabilities"
          }
        }
      },
      "RecordingJob": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "jobId",
          "sessionId",
          "displayName",
          "sessionMode",
          "sessionOrigin",
          "status",
          "route",
          "captureManifest",
          "createdAtUtc",
          "updatedAtUtc"
        ],
        "properties": {
          "jobId": {
            "$ref": "#/components/schemas/JobId"
          },
          "sessionId": {
            "$ref": "#/components/schemas/OpaqueIdentifier"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "sessionMode": {
            "$ref": "#/components/schemas/SessionMode"
          },
          "sessionOrigin": {
            "$ref": "#/components/schemas/SessionOrigin"
          },
          "status": {
            "$ref": "#/components/schemas/RecordingJobStatus"
          },
          "route": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/AudioRoute"
              },
              {
                "type": "null"
              }
            ]
          },
          "captureManifest": {
            "$ref": "#/components/schemas/CaptureManifestReference"
          },
          "progressPercent": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 100
          },
          "progressMessage": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 512
          },
          "error": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/ApiError"
              },
              {
                "type": "null"
              }
            ]
          },
          "createdAtUtc": {
            "$ref": "#/components/schemas/UtcDateTime"
          },
          "updatedAtUtc": {
            "$ref": "#/components/schemas/UtcDateTime"
          }
        }
      },
      "CreateRecordingJobRequest": {
        "type": "object",
        "additionalProperties": false,
        "description": "Phase 5 upload-intake request. Identity ownership is server-derived after token validation; privacyPolicyVersion unconfigured cannot authorize a team upload once policy gating ships.",
        "required": [
          "displayName",
          "metadata",
          "tracks",
          "route",
          "captureManifest",
          "chunks"
        ],
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "metadata": {
            "$ref": "#/components/schemas/SessionMetadata"
          },
          "tracks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/CaptureTrackDescriptor"
            }
          },
          "route": {
            "type": "string",
            "const": "server_batch"
          },
          "captureManifest": {
            "$ref": "#/components/schemas/CaptureManifestReference"
          },
          "chunks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/CaptureChunkReference"
            }
          }
        }
      },
      "CommitRecordingJobRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "captureManifest",
          "chunkCount"
        ],
        "properties": {
          "captureManifest": {
            "$ref": "#/components/schemas/CaptureManifestReference"
          },
          "chunkCount": {
            "type": "integer",
            "minimum": 1
          }
        }
      },
      "ChunkUploadReceipt": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "replayKey",
          "contentIdentity",
          "disposition",
          "acceptedAtUtc"
        ],
        "properties": {
          "replayKey": {
            "$ref": "#/components/schemas/ChunkReplayKey"
          },
          "contentIdentity": {
            "$ref": "#/components/schemas/ContentIdentity"
          },
          "disposition": {
            "type": "string",
            "enum": [
              "accepted",
              "replayed"
            ]
          },
          "acceptedAtUtc": {
            "$ref": "#/components/schemas/UtcDateTime"
          }
        }
      },
      "ApiError": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message",
          "retryable",
          "requestId"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[A-Z][A-Z0-9_]*$"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "retryable": {
            "type": "boolean"
          },
          "requestId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "example": {
          "code": "SERVER_BUSY",
          "message": "Server capacity is temporarily unavailable.",
          "retryable": true,
          "requestId": "req-01J..."
        }
      }
    }
  }
}
