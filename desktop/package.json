{
  "name": "yap-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "check:node": "node ./tests/scripts/assert-node24.mjs",
    "dev": "pnpm check:node && vite",
    "build": "pnpm check:node && tsc && vite build",
    "preview": "pnpm check:node && vite preview",
    "tauri": "pnpm check:node && tauri",
    "test": "pnpm check:node && vitest run",
    "test:release-contract": "pnpm check:node && node --test ./tests/scripts/release-evidence.contract.mjs",
    "test:e2e": "pnpm check:node && node ./tests/scripts/run-playwright-e2e.mjs",
    "test:e2e:update": "pnpm check:node && node ./tests/scripts/run-playwright-e2e.mjs --update-snapshots",
    "test:desktop": "pnpm check:node && wdio run ./tests/wdio.conf.ts",
    "test:desktop:build": "pnpm check:node && node ./tests/scripts/tauri-wdio-build.mjs",
    "test:desktop:all": "pnpm test:desktop:build && pnpm test:desktop",
    "test:phase5-gate": "pnpm test:desktop:build && pnpm check:node && wdio run ./tests/wdio.phase5-gate.conf.ts",
    "test:nsis:disposable": "pnpm check:node && pwsh.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File ./tests/scripts/smoke-nsis.ps1"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/tauri-plugin": "^1.2.0",
    "@wdio/tauri-service": "^1.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "webdriverio": "^9.27.1",
    "yaml": "^2.9.0"
  }
}
