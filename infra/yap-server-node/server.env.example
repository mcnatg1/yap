# Copy to a local env file and edit before running setup-server.sh.

# Owner of /srv/yap-server and allowed SSH user.
YAP_OWNER=admin
YAP_GROUP=admin

# Hardware profile. This is metadata for docs/reports; host-specific settings
# below do the real work.
YAP_HARDWARE_PROFILE=dgx-spark-gb10

# App workspace on the server node.
YAP_SERVER_ROOT=/srv/yap-server

# Demo/private management link.
YAP_PRIVATE_IFACE=enP7s7
YAP_PRIVATE_ADDR=192.168.50.1/24
YAP_PRIVATE_SSH_FROM=192.168.50.63
# One representative client IP from the configured management source ranges.
# setup-server.sh evaluates sshd's effective Match context for this address and
# refuses to reload SSH if the key-only/user/forwarding policy differs.
YAP_SSH_POLICY_TEST_ADDR=192.168.50.63
YAP_CONFIGURE_PRIVATE_ETHERNET=0

# Corporate/LAN management access. Empty by default; opt in only after the
# effective firewall and approved admin source range are known.
YAP_LAN_SSH_CIDR=
YAP_OVERLAY_SSH_CIDR=

# Future Zscaler/ZPA mode.
# Usually the server node should allow the Zscaler connector/client CIDR rather
# than the whole corporate wireless subnet.
YAP_ZSCALER_APP_CIDR=
YAP_ZSCALER_SSH_CIDR=

# Future app entrypoint. Leave empty until yap-server exists.
YAP_APP_PORT=
YAP_APP_CIDR=

# Setup behavior is conservative by default. A fresh dedicated node may opt in
# to a firewall reset or desktop/peripheral cleanup after explicit review.
YAP_FIREWALL_RESET=0
# Firewall reset is local-console-only. Set this exact acknowledgement only
# while physically at the server with a tested recovery path.
YAP_FIREWALL_RESET_CONFIRM=
YAP_DISABLE_NOISE_SERVICES=0
YAP_TUNNEL_ONLY_PORTS="3389 5909 11000 11434 18765"

# Validate values and host prerequisites without requiring root or changing the
# host. Leave at 0 for a real setup run.
YAP_VALIDATE_ONLY=0
